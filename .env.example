# Copy to .env and fill in real values. Never commit .env.
# Database: Neon PostgreSQL (https://neon.tech) – credentials stay server-side only.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
NEXTAUTH_URL="http://localhost:3009"
NEXTAUTH_SECRET="your-secret-at-least-32-chars"

# Email (password reset). Get a free key at https://resend.com
# If RESEND_API_KEY is empty, reset links are logged to the server console instead of emailed.
RESEND_API_KEY=""
EMAIL_FROM="BookMeBz <no-reply@bookme.bz>"

# After adding RateLimitEntry to the schema, run: npx prisma db push
# (or npx prisma migrate dev) so production rate limiting works.
